# ============================================
# SERVER-SIDE SECRETS (used by server.js)
# Copy this file to .env and fill in your keys
# ============================================

# Clarifai
CLARIFAI_API_KEY=your_clarifai_api_key_here
CLARIFAI_USER_ID=your_clarifai_user_id
CLARIFAI_APP_ID=your_clarifai_app_id
CLARIFAI_MODEL_ID=general-image-recognition
CLARIFAI_MODEL_VERSION_ID=aa7f35c01e0642fda5cf400f543e7c40

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap
WEATHER_API_KEY=your_openweathermap_api_key_here
